# CHINJU Sidecar Configuration
# Copy this file to .env and fill in your values

# OpenAI API (Required for API mode, leave empty for mock mode)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG_ID=

# Server Ports
CHINJU_GRPC_PORT=50051
CHINJU_HTTP_PORT=8080

# Audit Logging
CHINJU_AUDIT_PATH=./data/audit/audit.jsonl
CHINJU_AUDIT_ARCHIVE=./data/audit/archive
