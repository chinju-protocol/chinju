{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chinju.org/schemas/human-credential.schema.json",
  "title": "Human Credential",
  "description": "CHINJU Protocol Human Credential (C12) - Proof of humanity and capability",
  "type": "object",
  "required": ["subject_id", "issuer_id", "validity", "humanity_proof"],
  "properties": {
    "subject_id": {
      "$ref": "#/$defs/identifier",
      "description": "Subject (credential holder) identifier"
    },
    "issuer_id": {
      "$ref": "#/$defs/identifier",
      "description": "Issuer identifier"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the credential was issued"
    },
    "validity": {
      "$ref": "#/$defs/validity_period",
      "description": "Validity period of the credential"
    },
    "humanity_proof": {
      "$ref": "#/$defs/humanity_proof",
      "description": "Zero-knowledge proof of humanity"
    },
    "capability": {
      "$ref": "#/$defs/capability_score",
      "description": "Capability score (C1: HCAL)"
    },
    "chain_proof": {
      "$ref": "#/$defs/chain_proof",
      "description": "Consciousness continuity chain"
    },
    "issuer_signature": {
      "$ref": "#/$defs/signature",
      "description": "Issuer's digital signature"
    },
    "attestation": {
      "$ref": "#/$defs/hardware_attestation",
      "description": "Hardware attestation"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Credential version"
    }
  },
  "$defs": {
    "identifier": {
      "type": "object",
      "required": ["namespace", "id"],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Namespace (e.g., 'user', 'chinju')"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Unique identifier within namespace"
        },
        "version": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional version number"
        }
      }
    },
    "validity_period": {
      "type": "object",
      "required": ["not_before", "not_after"],
      "properties": {
        "not_before": {
          "type": "string",
          "format": "date-time",
          "description": "Valid from this time"
        },
        "not_after": {
          "type": "string",
          "format": "date-time",
          "description": "Valid until this time"
        }
      }
    },
    "humanity_proof": {
      "type": "object",
      "required": ["proof_type", "zkp_data"],
      "properties": {
        "proof_type": {
          "type": "string",
          "enum": ["biometric_response", "cognitive_pattern", "composite"],
          "description": "Type of humanity proof"
        },
        "zkp_data": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Zero-knowledge proof data"
        },
        "public_params": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Public parameters for verification"
        },
        "degradation": {
          "$ref": "#/$defs/degradation_score"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "degradation_score": {
      "type": "object",
      "description": "Proves human finiteness (AI doesn't degrade)",
      "properties": {
        "fatigue": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Cumulative fatigue (0.0 - 1.0)"
        },
        "attention_decay": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Attention decay (0.0 - 1.0)"
        },
        "response_variance": {
          "type": "number",
          "minimum": 0,
          "description": "Response time variance"
        },
        "measured_at": {
          "type": "string",
          "format": "date-time"
        },
        "within_human_range": {
          "type": "boolean",
          "description": "Whether values are within normal human range"
        }
      }
    },
    "capability_score": {
      "type": "object",
      "description": "C1: HCAL capability scores",
      "properties": {
        "independence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Independence from AI suggestions"
        },
        "detection": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Anomaly detection ability"
        },
        "alternatives": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Alternative generation ability"
        },
        "critique": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Critical evaluation ability"
        },
        "total": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Total weighted score"
        },
        "context": {
          "$ref": "#/$defs/measurement_context"
        }
      }
    },
    "measurement_context": {
      "type": "object",
      "properties": {
        "measured_at": {
          "type": "string",
          "format": "date-time"
        },
        "environment_id": {
          "type": "string",
          "description": "TEE enclave ID or environment identifier"
        },
        "test_version": {
          "type": "string"
        }
      }
    },
    "chain_proof": {
      "type": "object",
      "description": "Consciousness continuity proof",
      "properties": {
        "previous_hash": {
          "$ref": "#/$defs/hash"
        },
        "chain_length": {
          "type": "integer",
          "minimum": 0
        },
        "recent_links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chain_link"
          },
          "maxItems": 10
        }
      }
    },
    "chain_link": {
      "type": "object",
      "properties": {
        "credential_hash": {
          "$ref": "#/$defs/hash"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature": {
          "$ref": "#/$defs/signature"
        }
      }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "public_key", "signature"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["ed25519", "ecdsa_p256", "ecdsa_p384"]
        },
        "public_key": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signature": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "key_id": {
          "type": "string"
        }
      }
    },
    "hash": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha3_256", "sha3_512", "blake3"]
        },
        "value": {
          "type": "string",
          "contentEncoding": "base64"
        }
      }
    },
    "hardware_attestation": {
      "type": "object",
      "properties": {
        "trust_level": {
          "type": "string",
          "enum": ["hardware_critical", "hardware_enterprise", "hardware_standard", "software", "mock"]
        },
        "hardware_type": {
          "type": "string",
          "description": "e.g., 'YubiHSM2', 'Intel SGX'"
        },
        "attestation_data": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "attested_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
